# =============================================================================
# Printix MCP — Environment-Konfiguration (v7.0.0, vereinfacht)
# =============================================================================
# Diese Datei nach `.env` kopieren und anpassen:
#   cp .env.example .env
#
# Ports & Port-Mappings werden AUSSCHLIESSLICH in docker-compose.yml gepflegt
# (Abschnitt `ports:`). Diese Datei enthält nur Laufzeit-Einstellungen.
# =============================================================================

# --- Image-Tag ---------------------------------------------------------------
# Welche Version aus ghcr.io/mnimtz/printix-mcp-docker gezogen wird.
# Beispiele: latest | 7.0.0 | main
PRINTIX_TAG=latest


# --- Öffentliche URL (einzige URL-Einstellung) -------------------------------
# Wenn via Reverse Proxy / Cloudflare Tunnel erreichbar:
#   z.B. https://mcp.example.com
# Wird im Banner, in OAuth-Redirects, Capture-Webhooks und Mail-Links verwendet.
#
# Alternative: Über die Admin-UI unter /admin/settings konfigurieren.
# DB-Setting überschreibt diese Env-Variable (ideal für Laufzeit-Änderungen).
#
# Leer lassen: Die Web-UI funktioniert dann über den Request-Host (LAN-Betrieb).
# Für öffentliche Links (Einladungs-Mails, Capture-Webhooks) ist ein expliziter
# Wert aber empfohlen.
MCP_PUBLIC_URL=


# --- Log-Level ---------------------------------------------------------------
# debug | info | warning | error | critical
MCP_LOG_LEVEL=info


# --- Capture-Server (optional) -----------------------------------------------
# false = Webhooks laufen über MCP-Port (8765), kein extra Port nötig. [Default]
# true  = eigener Server auf Port 8775 (muss in docker-compose.yml gemapped sein).
# Wenn Du eine dedizierte Capture-DOMAIN brauchst, konfiguriere sie in der
# Admin-UI unter /admin/settings → "Capture Public URL".
CAPTURE_ENABLED=false


# --- IPP/IPPS Cloud-Print (optional) -----------------------------------------
# 0   = deaktiviert (IPP läuft nur auf WEB_PORT, reicht für die meisten Setups).
# 631 = Standard-IPP-Port (braucht IPPS_CERTFILE + IPPS_KEYFILE für IPPS).
# Wenn aktiv: Port 631 in docker-compose.yml einkommentieren.
IPP_PORT=0

# TLS-Zertifikate für IPPS (nur wenn IPP_PORT > 0).
# Pfade sind Container-intern — Zertifikats-Ordner als Volume in /certs:ro mounten.
# Beispiel:
#   IPPS_CERTFILE=/certs/fullchain.pem
#   IPPS_KEYFILE=/certs/privkey.pem
IPPS_CERTFILE=
IPPS_KEYFILE=
