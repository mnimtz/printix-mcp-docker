# =============================================================================
# Printix MCP — environment configuration (v7.0.0+, simplified)
# =============================================================================
# Copy this file to `.env` and adjust:
#   cp .env.example .env
#
# Ports and port mappings live EXCLUSIVELY in docker-compose.yml (the `ports:`
# section). This file only holds runtime settings.
# =============================================================================

# --- Image tag ---------------------------------------------------------------
# Which version to pull from ghcr.io/mnimtz/printix-mcp-docker.
# Examples: latest | 7.0.0 | main
PRINTIX_TAG=latest


# --- Public URL (the only URL setting) ---------------------------------------
# When reachable via reverse proxy / Cloudflare Tunnel:
#   e.g. https://mcp.example.com
# Used in the banner, in OAuth redirects, capture webhooks and mail links.
#
# Alternative: configure it via the admin UI under /admin/settings.
# The DB setting overrides this env var (best for runtime changes).
#
# Leave empty: the web UI then works through the request host (LAN mode).
# For public links (invitation mails, capture webhooks) an explicit value
# is still recommended.
MCP_PUBLIC_URL=


# --- Log level ---------------------------------------------------------------
# debug | info | warning | error | critical
MCP_LOG_LEVEL=info


# --- Capture server (optional) -----------------------------------------------
# false = webhooks go through the MCP port (8765), no extra port needed. [default]
# true  = dedicated server on port 8775 (must be mapped in docker-compose.yml).
# If you need a dedicated capture DOMAIN, configure it in the admin UI
# under /admin/settings → "Capture Public URL".
CAPTURE_ENABLED=false


# --- Container timezone ------------------------------------------------------
# IANA name. Affects `docker logs` and all subprocess timestamps. The web UI
# also has a Display Timezone setting (Administration → Settings) but that
# only changes rendered tables, not container/MCP/capture stdout. Default is
# Europe/Berlin; switch to UTC, America/New_York, Asia/Tokyo, etc. as needed.
TZ=Europe/Berlin


# --- IPP/IPPS cloud-print (optional) -----------------------------------------
# 0   = disabled (IPP only runs on WEB_PORT, enough for most setups).
# 631 = standard IPP port (needs IPPS_CERTFILE + IPPS_KEYFILE for IPPS).
# When active: uncomment port 631 in docker-compose.yml.
IPP_PORT=0

# TLS certificates for IPPS (only when IPP_PORT > 0).
# Paths are container-internal — mount the certs folder as a /certs:ro volume.
# Example:
#   IPPS_CERTFILE=/certs/fullchain.pem
#   IPPS_KEYFILE=/certs/privkey.pem
IPPS_CERTFILE=
IPPS_KEYFILE=
