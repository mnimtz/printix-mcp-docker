# =============================================================================
# Printix MCP — Environment-Konfiguration
# =============================================================================
# Diese Datei nach `.env` kopieren und anpassen:
#   cp .env.example .env
#
# Alle Variablen sind optional — Defaults in docker-compose.yml greifen.
# =============================================================================

# --- Image-Tag ---------------------------------------------------------------
# Welche Version aus ghcr.io/mnimtz/printix-mcp-docker gezogen wird.
# Beispiele: latest | 6.7.118 | 6.7 | main
PRINTIX_TAG=latest


# --- Host-Ports --------------------------------------------------------------
# Welche Ports auf dem Host exponiert werden (= was Nutzer im Browser/Tunnel ansprechen).
# Container-Ports sind intern fix (8080/8765/8775/631).
HOST_WEB_PORT=8080
HOST_MCP_PORT=8765
HOST_CAPTURE_PORT=8775
# HOST_IPP_PORT=631


# --- Öffentliche URL ---------------------------------------------------------
# Wenn via Reverse Proxy / Cloudflare Tunnel erreichbar:
#   z.B. https://mcp.example.com
# Wird im Banner, im OAuth-Redirect und im QR-Code der Mobile-App verwendet.
# Leer lassen für reinen LAN-Betrieb.
MCP_PUBLIC_URL=
CAPTURE_PUBLIC_URL=


# --- Log-Level ---------------------------------------------------------------
# debug | info | warning | error | critical
MCP_LOG_LEVEL=info


# --- Capture-Server ----------------------------------------------------------
# Separater Port für Capture-Webhooks (Papercut-Style Follow-Me-Print).
# false = Webhooks laufen über MCP-Port (8765), kein extra Port nötig.
# true  = eigener Server auf CAPTURE_PORT (8775 im Container).
CAPTURE_ENABLED=false


# --- IPP/IPPS Cloud-Print ----------------------------------------------------
# 0 = deaktiviert (IPP läuft nur auf WEB_PORT, reicht für die meisten Setups).
# 631 = Standard-IPP-Port (braucht IPPS_CERTFILE + IPPS_KEYFILE für IPPS).
# Wenn du IPP aktivierst, musst du auch die HOST_IPP_PORT-Zeile oben und den
# Port-Mapping-Eintrag in docker-compose.yml einkommentieren.
IPP_PORT=0

# TLS-Zertifikate für IPPS (nur wenn IPP_PORT gesetzt).
# Pfade sind Container-intern — Zertifikats-Ordner als Volume in /certs:ro mounten.
# Beispiel:
#   IPPS_CERTFILE=/certs/fullchain.pem
#   IPPS_KEYFILE=/certs/privkey.pem
IPPS_CERTFILE=
IPPS_KEYFILE=
